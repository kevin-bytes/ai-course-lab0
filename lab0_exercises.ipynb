    "import numpy as np\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"EXERCISE 4: NumPy Array Operations\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# TASK 1: Create a 5x5 matrix where border elements are 1 and interior is 0 (5 points)\n",
    "print(\"\\n--- Task 1: 5x5 Border Matrix ---\")\n",
    "\n",
    "# Create a 5x5 matrix of zeros\n",
    "matrix = np.zeros((5, 5))\n",
    "\n",
    "# Set border elements to 1\n",
    "matrix[0, :] = 1      # Top row\n",
    "matrix[-1, :] = 1     # Bottom row\n",
    "matrix[:, 0] = 1      # Left column\n",
    "matrix[:, -1] = 1     # Right column\n",
    "\n",
    "print(\"5x5 Matrix with border 1, interior 0:\")\n",
    "print(matrix)\n",
    "\n",
    "# TASK 2: Normalize a random array (5 points)\n",
    "print(\"\\n--- Task 2: Normalize Random Array ---\")\n",
    "\n",
    "np.random.seed(42)\n",
    "random_data = np.random.randn(100, 3)\n",
    "\n",
    "print(\"Before normalization:\")\n",
    "print(f\"  Column 1 - Mean: {random_data[:, 0].mean():.4f}, Std: {random_data[:, 0].std():.4f}\")\n",
    "print(f\"  Column 2 - Mean: {random_data[:, 1].mean():.4f}, Std: {random_data[:, 1].std():.4f}\")\n",
    "print(f\"  Column 3 - Mean: {random_data[:, 2].mean():.4f}, Std: {random_data[:, 2].std():.4f}\")\n",
    "\n",
    "# Normalize each column to have mean=0 and std=1\n",
    "normalized_data = (random_data - random_data.mean(axis=0)) / random_data.std(axis=0)\n",
    "\n",
    "print(\"\\nAfter normalization:\")\n",
    "print(f\"  Column 1 - Mean: {normalized_data[:, 0].mean():.4f}, Std: {normalized_data[:, 0].std():.4f}\")\n",
    "print(f\"  Column 2 - Mean: {normalized_data[:, 1].mean():.4f}, Std: {normalized_data[:, 1].std():.4f}\")\n",
    "print(f\"  Column 3 - Mean: {normalized_data[:, 2].mean():.4f}, Std: {normalized_data[:, 2].std():.4f}\")\n",
    "\n",
    "# TASK 3: Linear regression using normal equation (10 points)\n",
    "print(\"\\n--- Task 3: Linear Regression with Normal Equation ---\")\n",
    "\n",
    "np.random.seed(42)\n",
    "X = np.random.randn(50, 3)\n",
    "true_theta = np.array([2.5, -1.2, 3.7])\n",
    "y = X @ true_theta + np.random.randn(50) * 0.1\n",
    "\n",
    "print(f\"True theta (actual coefficients): {true_theta}\")\n",
    "print(f\"First 5 rows of X (features):\\n{X[:5]}\")\n",
    "print(f\"First 5 values of y (target): {y[:5]}\")\n",
    "\n",
    "# Calculate theta_hat using the normal equation: theta = (X^T X)^(-1) X^T y\n",
    "theta_hat = np.linalg.inv(X.T @ X) @ X.T @ y\n",
    "\n",
    "print(f\"\\nEstimated theta: {theta_hat.round(4)}\")\n",
    "print(f\"Difference from true theta: {(theta_hat - true_theta).round(4)}\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 50)\n",
    "print(\"EXERCISE 4 COMPLETE!\")\n",
    "print(\"=\" * 50)"
   ]
  },
