    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Set style\n",
    "sns.set_style(\"whitegrid\")\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"EXERCISE 6: Data Visualization\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Task 1: Distribution Visualization (8 points)\n",
    "print(\"\\n--- Task 1: Distribution Visualization ---\")\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Left: Histogram of exam scores with KDE overlay\n",
    "sns.histplot(data=df, x='exam_score', kde=True, ax=ax1, color='steelblue')\n",
    "ax1.set_title('Distribution of Exam Scores', fontsize=14)\n",
    "ax1.set_xlabel('Exam Score')\n",
    "ax1.set_ylabel('Frequency')\n",
    "\n",
    "# Right: Box plot of exam scores by major\n",
    "sns.boxplot(data=df, x='major', y='exam_score', ax=ax2)\n",
    "ax2.set_title('Exam Scores by Major', fontsize=14)\n",
    "ax2.set_xlabel('Major')\n",
    "ax2.set_ylabel('Exam Score')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Task 2: Relationship Visualization (8 points)\n",
    "print(\"\\n--- Task 2: Relationship Visualization ---\")\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "\n",
    "# Scatter plot colored by major\n",
    "sns.scatterplot(data=df, x='hours_studied', y='exam_score', hue='major', size='major', sizes=(50, 200), alpha=0.7)\n",
    "\n",
    "# Add regression line\n",
    "sns.regplot(data=df, x='hours_studied', y='exam_score', scatter=False, color='red', label='Regression Line')\n",
    "\n",
    "plt.title('Hours Studied vs Exam Score', fontsize=14)\n",
    "plt.xlabel('Hours Studied per Week', fontsize=12)\n",
    "plt.ylabel('Exam Score', fontsize=12)\n",
    "plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Task 3: Advanced Dashboard (9 points)\n",
    "print(\"\\n--- Task 3: Advanced Dashboard ---\")\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 12))\n",
    "\n",
    "# 1. Bar chart: Average exam score by major\n",
    "avg_scores = df.groupby('major')['exam_score'].mean().sort_values()\n",
    "axes[0, 0].bar(avg_scores.index, avg_scores.values, color='steelblue')\n",
    "axes[0, 0].set_title('Average Exam Score by Major', fontsize=14)\n",
    "axes[0, 0].set_xlabel('Major')\n",
    "axes[0, 0].set_ylabel('Average Exam Score')\n",
    "axes[0, 0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# 2. Count plot: Number of students by year\n",
    "year_counts = df['year'].value_counts().sort_index()\n",
    "axes[0, 1].bar(year_counts.index, year_counts.values, color='coral')\n",
    "axes[0, 1].set_title('Number of Students by Year', fontsize=14)\n",
    "axes[0, 1].set_xlabel('Year')\n",
    "axes[0, 1].set_ylabel('Count')\n",
    "\n",
    "# 3. Heat map: Correlation matrix\n",
    "numerical_cols = ['exam_score', 'assignments_completed', 'hours_studied']\n",
    "corr_matrix = df[numerical_cols].corr()\n",
    "sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', center=0, ax=axes[1, 0], square=True)\n",
    "axes[1, 0].set_title('Correlation Matrix', fontsize=14)\n",
    "\n",
    "# 4. Violin plot: Exam score by performance\n",
    "sns.violinplot(data=df, x='performance', y='exam_score', ax=axes[1, 1], palette='Set2')\n",
    "axes[1, 1].set_title('Exam Score Distribution by Performance', fontsize=14)\n",
    "axes[1, 1].set_xlabel('Performance Category')\n",
    "axes[1, 1].set_ylabel('Exam Score')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n\" + \"=\" * 50)\n",
    "print(\"EXERCISE 6 COMPLETE!\")\n",
    "print(\"=\" * 50)"
   ]
